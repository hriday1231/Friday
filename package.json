{
  "name": "friday-assistant",
  "productName": "Friday",
  "version": "1.0.0",
  "description": "Friday - Personal AI Assistant with MCP Integration",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "install-shortcut": "powershell -ExecutionPolicy Bypass -File scripts/install-start-menu-shortcut.ps1",
    "eval": "node scripts/eval.js",
    "eval:search": "node scripts/eval.js --filter search",
    "eval:chat": "node scripts/eval.js --filter chat",
    "eval:verbose": "node scripts/eval.js --verbose"
  },
  "keywords": [
    "electron",
    "ai",
    "assistant",
    "mcp"
  ],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@highlightjs/cdn-assets": "^11.11.1",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "axios": "^1.7.0",
    "dotenv": "^16.4.0",
    "electron-store": "^8.2.0",
    "googleapis": "^171.4.0",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "katex": "^0.16.40",
    "marked": "^17.0.1",
    "pdf-parse": "^2.4.5",
    "sql.js": "^1.14.1",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "@modelcontextprotocol/server-brave-search": "^1.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "build": {
    "appId": "com.friday.assistant",
    "productName": "Friday",
    "files": [
      "src/**/*",
      "!src/renderer/rag/**",
      "package.json"
    ],
    "win": {
      "target": ["nsis"],
      "icon": "public/icon.ico"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "public/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "icon": "public/icons",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
