# Cloud LLM provider keys (all optional — Friday falls back to whichever you set)
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Brave Search API (used by the brave_web_search tool)
BRAVE_API_KEY=

# Ollama Configuration (local inference)
OLLAMA_BASE_URL=http://localhost:11434

# Application Settings
DEFAULT_MODEL=gemini
HOTKEY=CommandOrControl+Shift+Space

# Calendar timezone (IANA, e.g. America/Los_Angeles for Pacific). Defaults to America/Los_Angeles.
# CALENDAR_TIMEZONE=America/Los_Angeles
